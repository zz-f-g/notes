   "source": [
    "## 参数方程问题\n",
    "$$\n",
    "\\begin{cases}\n",
    "    x = 1 - e^{at} \\\\\n",
    "    y = at - e^{-at}\n",
    "\\end{cases} \\\\\n",
    "\\frac{\\mathrm{d}^3 y}{\\mathrm{d} x^3}?\n",
    "$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  3                         \n",
      " d ⎛(x - 1)⋅log(-x + 1) + 1⎞\n",
      "───⎜───────────────────────⎟\n",
      "  3⎝         x - 1         ⎠\n",
      "dx                          \n"
     ]
    }
   ],
   "source": [
    "from sympy import *\n",
    "from sympy.abc import x\n",
    "y = ln(1-x) - 1/(1-x)\n",
    "pprint(Derivative(y,x,3).simplify())"
   ]
  }
